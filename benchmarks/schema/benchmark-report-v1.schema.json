{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/chaitanyarahalkar/packforge/benchmarks/schema/benchmark-report-v1.schema.json",
  "title": "Packforge native executable benchmark report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_utc",
    "source_commit",
    "source_run_url",
    "environment",
    "tools",
    "configuration",
    "fixtures",
    "gates"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "generated_at_utc": {"type": "string", "format": "date-time"},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "source_run_url": {"type": "string"},
    "environment": {"$ref": "#/$defs/environment"},
    "tools": {"$ref": "#/$defs/tools"},
    "configuration": {"$ref": "#/$defs/configuration"},
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/fixture"}
    },
    "gates": {"$ref": "#/$defs/gates"}
  },
  "$defs": {
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "kernel", "architecture", "cpu", "runner"],
      "properties": {
        "os": {"type": "string", "minLength": 1},
        "kernel": {"type": "string", "minLength": 1},
        "architecture": {"const": "x86_64"},
        "cpu": {"type": "string", "minLength": 1},
        "runner": {"type": "string", "minLength": 1}
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cc", "cpp", "rustc", "go", "packforge", "upx"],
      "properties": {
        "cc": {"type": "string", "minLength": 1},
        "cpp": {"type": "string", "minLength": 1},
        "rustc": {"type": "string", "minLength": 1},
        "go": {"type": "string", "minLength": 1},
        "packforge": {"type": "string", "minLength": 1},
        "upx": {"const": "5.2.0"}
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packforge_profile",
        "upx_mode",
        "warmup_iterations",
        "warm_iterations",
        "cold_iterations",
        "cold_cache_reset"
      ],
      "properties": {
        "packforge_profile": {"const": "fast"},
        "upx_mode": {"const": "--best"},
        "warmup_iterations": {"type": "integer", "minimum": 1},
        "warm_iterations": {"type": "integer", "minimum": 3, "maximum": 101},
        "cold_iterations": {"type": "integer", "minimum": 0, "maximum": 31},
        "cold_cache_reset": {
          "enum": ["none", "linux_drop_caches_3"]
        }
      }
    },
    "samples": {
      "type": "object",
      "additionalProperties": false,
      "required": ["median", "values"],
      "properties": {
        "median": {"type": "integer", "minimum": 0},
        "values": {
          "type": "array",
          "items": {"type": "integer", "minimum": 0}
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "bytes",
        "ratio_basis_points",
        "sha256",
        "behavior_matches_original",
        "reversible",
        "deterministic",
        "warm_time_ns",
        "cold_time_ns",
        "peak_rss_kib"
      ],
      "properties": {
        "kind": {"enum": ["original", "packforge", "upx"]},
        "bytes": {"type": "integer", "minimum": 1},
        "ratio_basis_points": {"type": "integer", "minimum": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "behavior_matches_original": {"type": "boolean"},
        "reversible": {"type": "boolean"},
        "deterministic": {"type": "boolean"},
        "warm_time_ns": {"$ref": "#/$defs/samples"},
        "cold_time_ns": {"$ref": "#/$defs/samples"},
        "peak_rss_kib": {"$ref": "#/$defs/samples"}
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "source_sha256", "artifacts"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "source": {"type": "string", "minLength": 1},
        "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "artifacts": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"$ref": "#/$defs/artifact"}
        }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correctness_pass",
        "size_limit_basis_points",
        "size_packforge_over_upx_basis_points",
        "size_pass",
        "cold_packforge_over_upx_basis_points",
        "cold_pass",
        "release_pass"
      ],
      "properties": {
        "correctness_pass": {"type": "boolean"},
        "size_limit_basis_points": {"const": 10500},
        "size_packforge_over_upx_basis_points": {"type": "integer", "minimum": 0},
        "size_pass": {"type": "boolean"},
        "cold_packforge_over_upx_basis_points": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "cold_pass": {"type": ["boolean", "null"]},
        "release_pass": {"type": "boolean"}
      }
    }
  }
}
